# ── Base de datos ──────────────────────────────────────────────
# LOCAL (desarrollo): dejá estas vacías → se usa el archivo SQLite prisma/dev.db.
# PRODUCCIÓN (Vercel): cargá estas dos con los datos de tu base Turso.
#   TURSO_DATABASE_URL  → turso db show <nombre> --url   (empieza con libsql://)
#   TURSO_AUTH_TOKEN    → turso db tokens create <nombre>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Prisma CLI (migraciones). En local usa el archivo si TURSO_DATABASE_URL está vacío.
DATABASE_URL="file:./prisma/dev.db"

# ── Acceso / seguridad ─────────────────────────────────────────
# MILESTER_PASSWORD: contraseña de acceso a la app. En PRODUCCIÓN (Vercel) cargala
#   sí o sí, si no la app queda abierta a cualquiera. Si está vacía, el login se
#   desactiva (cómodo para desarrollo local).
# MILESTER_ENABLED: interruptor on/off. Poné "false" para "apagar" (modo
#   mantenimiento, bloquea todo). Cualquier otro valor o vacío = encendido.
MILESTER_PASSWORD=
MILESTER_ENABLED=
