generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Settings {
  id                Int      @id @default(autoincrement())
  storeId           String?
  accessToken       String?
  appId             String?  // Tienda Nube App / Client ID (for OAuth)
  clientSecret      String?  // Tienda Nube Client Secret (for OAuth)
  oauthState        String?  // CSRF state for the in-progress OAuth flow
  anthropicApiKey   String?
  lastChangeCheckAt DateTime? // last time we scanned TN for incoming product changes
  lastOrderSyncAt   DateTime? // last time we pulled incremental order/sales updates
  lastCampaignTickAt DateTime? // last time the campaign scheduler ran
  lastCatalogSyncAt DateTime? // last incremental catalog (products+collections) pull from TN
  lastPullAt        DateTime? // last time the unified "pull current state" sync ran
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Incoming changes detected on Tienda Nube, awaiting the developer's approval.
model IncomingChange {
  id           Int      @id @default(autoincrement())
  tiendaNubeId String   // TN product id
  productId    Int?     // local product id, null if the product is new on TN
  productName  String
  field        String   // name | price | published | stock | tags | categories | new
  localValue   String?
  remoteValue  String?
  conflict     Boolean  @default(false) // true if the local product also has unsynced edits
  detectedAt   DateTime @default(now())

  @@unique([tiendaNubeId, field])
}

model Product {
  id             Int         @id @default(autoincrement())
  tiendaNubeId   String?     @unique
  name           String
  /// Solo lectura: columna GENERADA por SQLite como lower(name). Existe para
  /// ordenar alfabéticamente sin distinguir mayúsculas (SQLite ordena en binario
  /// y dejaba "eFootball"/"inFAMOUS" después de la Z). NUNCA escribirla: la base
  /// la calcula sola y rechaza cualquier INSERT/UPDATE sobre esta columna.
  nameSort       String?
  description    String?
  price          Float              // base price
  promotionalPrice Float?           // TN promotional_price (active sale price); null = no sale
  originalPrice  Float
  seoTitle       String?
  seoDescription String?
  imageUrl       String?
  categoryId     String?
  categoryName   String?
  stock          Int?
  infiniteStock  Boolean   @default(false)  // TN "stock ilimitado" (variante sin gestión de stock)
  attributes     String    @default("[]")   // JSON array of variant attribute names, e.g. ["Plataforma","Cuenta"]
  sku            String?
  requiresShipping Boolean?                  // TN: false = Digital/Servicio. null = desconocido (no se envía)
  published      Boolean   @default(true)
  tags           String    @default("[]")
  variants       Variant[]
  changelog      Changelog[]
  syncStatus     String      @default("pending")
  pendingDelete  Boolean     @default(false)  // staged for deletion; removed from TN + local on next sync
  lastSyncedAt   DateTime?
  unitsSold      Int         @default(0)   // denormalized from order items
  lastSoldAt     DateTime?                 // most recent sale date
  orderItems     OrderItem[]
  campaignItems  CampaignItem[]
  categories     ProductCategory[]
  descriptionTemplateId Int?                 // DescriptionTemplate applied to build `description`
  descriptionTemplate   DescriptionTemplate? @relation(fields: [descriptionTemplateId], references: [id], onDelete: SetNull)
  descriptionData       String?              // JSON: slot values for the applied template
  imageTemplateId Int?                       // ImageTemplate (background + cover frame) applied to the image
  imageTemplate   ImageTemplate? @relation(fields: [imageTemplateId], references: [id], onDelete: SetNull)
  productImageUrl String?                    // raw product-layer image URL, composited under the cover
  imageDirty     Boolean     @default(false) // local image differs from TN's — upload it on the next push
  // What the product cost in USD. Local-only: Tienda Nube has no field for it, so
  // it never syncs and never marks the product dirty. Optional — most of the
  // catalog is priced in USD, but not all of it.
  costUsd        Float?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // The sidebar's pending-push counters filter on these constantly; without the
  // indexes each count was a full scan of the table (the main driver of the
  // Turso read-quota blowout).
  @@index([syncStatus])
  @@index([pendingDelete])
  @@index([nameSort])
}

model DescriptionTemplate {
  id        Int       @id @default(autoincrement())
  name      String
  skeleton  String                          // HTML skeleton with {{slot}} tokens + <!--repeat:key--> regions
  fields    String    @default("[]")        // JSON schema of slots (key, label, type, item/pairs config)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// Plantilla de PRODUCTO: define versiones comerciales (PS4, PS5, Secundaria…)
/// y la herencia común (colecciones, tags, plantillas de descripción/imagen).
/// El wizard "Crear producto" del catálogo genera un producto staged
/// independiente por cada versión seleccionada. Las versiones viven como JSON
/// para poder agregar plataformas/tipos sin migrar el schema.
model ProductTemplate {
  id                    Int      @id @default(autoincrement())
  name                  String                   // "Juegos Digitales"
  versions              String   @default("[]")  // JSON: [{ key, label, namePattern, skuSuffix, descriptionTemplateId, imageTemplateId, categoryIds }]
  categoryIds           String   @default("[]")  // LEGACY: fallback si la versión no define categoryIds propios
  tags                  String   @default("[]")  // JSON string[] — tags iniciales (comunes a todas las versiones)
  descriptionTemplateId Int?                     // LEGACY: fallback si la versión no define el suyo
  imageTemplateId       Int?                     // LEGACY: fallback si la versión no define el suyo
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ImageTemplate {
  id            Int       @id @default(autoincrement())
  name          String
  backgroundUrl String                        // canvas/background layer (1024x1024)
  coverUrl      String                        // frame layer (670x763), drawn on top
  shadowOffsetX Int       @default(-6)         // generated drop-shadow params
  shadowOffsetY Int       @default(18)
  shadowBlur    Int       @default(20)
  shadowOpacity Float     @default(0.5)
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Category {
  id           Int               @id @default(autoincrement())
  tiendaNubeId String            @unique
  name         String
  parentTnId   String?           // TN parent id; "0" or null = root
  products     ProductCategory[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ProductCategory {
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model Campaign {
  id            Int            @id @default(autoincrement())
  name          String
  status        String         @default("draft")  // draft | active | ended
  discountType  String                            // pct | fixed
  discountValue Float
  addTag        String?                           // tag to add to affected products
  addCategoryId Int?                              // local Category id to add products to (optional)
  scope         String         @default("all")    // all | category | tag | products
  scopeValue    String?                           // category name or tag, depending on scope
  startDate     DateTime?
  endDate       DateTime?
  appliedAt     DateTime?
  endedAt       DateTime?
  items         CampaignItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model CampaignItem {
  id            Int      @id @default(autoincrement())
  campaignId    Int
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  originalPrice Float    // snapshot taken when the campaign was applied, for revert
  campaignPrice Float    // product-level promo (single-variant, or the lowest-id variant)
  variantPrices String   @default("[]") // JSON [{ variantId, campaignPrice }] for multi-variant products
}

model Order {
  id            Int         @id @default(autoincrement())
  // Null while the order only exists here: a manual ticket taken over WhatsApp
  // has no Tienda Nube id until (and unless) it is pushed there.
  tiendaNubeId  String?     @unique
  number        Int?
  total         Float
  status        String      // open | closed | cancelled
  paymentStatus String?
  customerName  String?
  customerId    Int?
  customer      Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  source        String      @default("tiendanube") // tiendanube | local
  orderedAt     DateTime    // Tienda Nube created_at

  // Manual ticket ("pedido de bar") fields — only meaningful when source = "local".
  fulfillmentState String?  // pending_payment | paid | delivered
  paymentReference String?  // transfer / MercadoPago operation number
  exchangeRate     Float?   // ARS per USD at sale time; snapshot so past margins stay honest
  linkedOrderId    Int?     // the web order this ticket corresponds to, so the sale isn't counted twice

  // Financial
  subtotal       Float?
  discount       Float?
  shippingCost   Float?
  totalPaid      Float?
  currency       String?
  paymentMethod  String?    // gateway_name

  // Shipping / fulfillment
  shippingStatus String?
  shippingMethod String?    // shipping_option
  shippingType   String?    // ship | pickup
  trackingNumber String?
  trackingUrl    String?
  shippingCarrier String?
  shippingAddress String?   // formatted single-line address for display

  // Lifecycle timestamps
  paidAt        DateTime?
  shippedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  closedAt      DateTime?

  // Notes & channel
  customerNote  String?
  ownerNote     String?
  channel       String?     // order_origin / storefront

  rawData       String?     // full TN order JSON snapshot

  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model Customer {
  id             Int      @id @default(autoincrement())
  tiendaNubeId   String?  @unique // TN customer id; null for locally-created customers
  name           String
  email          String?
  phone          String?
  identification String?  // DNI / CUIT — strongest dedup key
  customerType   String?  // person | business
  businessName   String?
  city           String?
  province       String?
  totalSpentTn   Float?   // TN's own total_spent figure
  acceptsMarketing Boolean?
  firstOrderAt   DateTime?
  mergedIntoId   Int?     // if set, this account was merged into another (duplicate)
  rawData        String?  // full TN customer JSON snapshot
  orders         Order[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productTnId String?  // Tienda Nube product id
  productId   Int?     // local product id, if matched
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name        String
  variantName String?  // edition / variant label
  sku         String?
  imageUrl    String?
  quantity    Int
  price       Float
  costUsd     Float?   // snapshot of the product's USD cost at sale time, for real margin
}

model Changelog {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String?
  synced    Boolean  @default(false)
  syncedAt  DateTime?
  createdAt DateTime @default(now())
}

model Variant {
  id               Int     @id @default(autoincrement())
  productId        Int
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tiendaNubeId     String?
  price            Float
  promotionalPrice Float?
  stock            Int?
  sku              String?
  values           String  @default("[]")  // JSON array of this variant's attribute values, e.g. ["PS5","Primario"]
}

model AiProvider {
  id        Int          @id @default(autoincrement())
  name      String
  provider  String       // "google" | "anthropic" | "openai"
  apiKey    String
  model     String
  isDefault Boolean      @default(false)
  templates AiTemplate[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model AiTemplate {
  id         Int         @id @default(autoincrement())
  context    String      // "description" | "seoTitle" | "seoDescription" | "name"
  label      String
  prompt     String
  providerId Int?
  provider   AiProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}


// Transformation jobs — "Dividir por variantes" and future catalog transforms.
// App-own data (class B): the preview/review state and the audit trail of what
// was generated from what. Backed up by scripts/backup.mjs.
model TransformationJob {
  id          Int      @id @default(autoincrement())
  type        String   // "split-variants" (extensible)
  status      String   @default("draft") // draft | completed | partial
  nameRule    String   // e.g. "{nombre_producto} - {nombre_variante}"
  confirmedAt DateTime?
  completedAt DateTime?
  items       TransformationItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TransformationItem {
  id               Int     @id @default(autoincrement())
  jobId            Int
  job              TransformationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceProductId  Int     // local Product id at preview time (not FK: source may be deleted later)
  sourceName       String  // snapshot for display even if the source changes
  sourceVariantId  Int?    // local Variant id (null if built from live TN data only)
  variantLabel     String  // "PS4" — what the name rule interpolates
  // Editable fields of the product-to-be (seeded from parent + variant):
  name             String
  price            Float
  promotionalPrice Float?
  stock            Int?    // null = infinite
  sku              String?
  // Review state:
  status           String  @default("ready") // ready | warning | error | edited | skipped | created
  issues           String  @default("[]")    // JSON [{level:"warning"|"error", code, message}]
  duplicateAction  String? // when a same-name product exists: "create" | "skip"
  targetProductId  Int?    // local Product created on confirm — the traceability link
  // Common data shared by every variant of the SAME source product, editable
  // once at the group level. JSON: { descriptionTemplateId, descriptionData,
  // imageTemplateId, productImageUrl, categoryIds:[], tags:[], seoTitle,
  // seoDescription }. Snapshotted from the parent at preview; a group edit
  // writes the same value to all its items. Empty {} = inherit the parent as-is.
  commonData       String  @default("{}")
}
